# ==========================================
# VALIDATION SERVICE - ENVIRONMENT VARIABLES
# ==========================================
# --- Database Credentials ---
# The Master Key (Used ONLY by Docker to build the database and run health checks)
DB_PASSWORD=your_root_database_password_here

# The App Key (Used by Spring Boot and your MySQL Workbench)
DB_USER=your_database_username
DB_USER_PASSWORD=your_database_password

# --- Security & JWT ---
JWT_SECRET=jwt_secret

# --- Razorpay Integration ---
# Get these from your Razorpay Dashboard (Test Mode)
RAZORPAY_KEY=rzp_test_your_key_here
RAZORPAY_SECRET=your_razorpay_secret_here
WEBHOOK_SECRET=your_custom_webhook_secret

# --- Rate Limiting (Redis) ---
REDIS_PASSWORD=your_redis_password_here